APP_NAME="Electricity Monitor"
# 生产环境请改成 false。false 时验证码邮件发送失败会直接报错，且不会把开发验证码返回给前端。
APP_DEBUG=false
SECRET_KEY="replace-with-a-random-secret-at-least-32-chars"
# 只有本地调试、并且你确认风险时才设为 true。
ALLOW_INSECURE_STARTUP=false
ACCESS_TOKEN_EXPIRE_MINUTES=10080
CORS_ORIGINS="http://127.0.0.1:5173,http://localhost:5173"
# 首次启动且数据库里还没有启用的管理员时，需要填写下面三项中的用户名和密码。
# 已经创建管理员后，可以从实际 .env 中删除 INITIAL_ADMIN_USERNAME / INITIAL_ADMIN_PASSWORD。
INITIAL_ADMIN_USERNAME=""
INITIAL_ADMIN_PASSWORD=""
INITIAL_ADMIN_DISPLAY_NAME=""

# Local database for development. This creates backend/dev.sqlite3 when you run the API from backend/.
DATABASE_URL="sqlite:///./dev.sqlite3"

# Later, when you are ready for PostgreSQL, change DATABASE_URL to something like:
# DATABASE_URL="postgresql+psycopg://sdu_power:change-this-dev-password@127.0.0.1:5432/sdu_power"

# Campus electricity API defaults.
ELECTRICITY_API_URL="https://mcard.sdu.edu.cn/charge/feeitem/getThirdData"
ELECTRICITY_API_TYPE="IEC"
ELECTRICITY_API_LEVEL="3"
ELECTRICITY_API_FEEITEMID="410"
ELECTRICITY_API_TIMEOUT=10

# Worker defaults. The API process no longer runs scheduled jobs; start them with:
# python -m app.worker
CHECK_INTERVAL_SECONDS=14400
CHECK_BATCH_SIZE=50
CHECK_REQUEST_DELAY_SECONDS=0.5
NOTIFY_INTERVAL_SECONDS=3600
NOTIFY_COOLDOWN_HOURS=12

# Low-power alert calculation.
# If a user does not set a fixed threshold, the platform uses:
# average_daily_usage * alert_days.
DEFAULT_ALERT_DAYS=1
DEFAULT_DAILY_USAGE_KWH=5.0
USAGE_HISTORY_DAYS=14
MAX_ROOMS_PER_USER=3

# Data retention. Set a value to 0 to disable automatic cleanup for that category.
VERIFICATION_CODE_RETENTION_DAYS=1
CHECK_ATTEMPT_RETENTION_DAYS=30
NOTIFICATION_RETENTION_DAYS=90
ELECTRICITY_READING_RETENTION_DAYS=365
ADMIN_AUDIT_LOG_RETENTION_DAYS=365
RETENTION_CLEANUP_HOUR=3

# Local files uploaded from the admin appearance page.
UPLOAD_DIR="./uploads"
APPEARANCE_UPLOAD_MAX_BYTES=5242880

# SMTP settings for verification codes and low-power emails.
# For QQ/163/Gmail-like providers, SMTP_PASSWORD is usually an app password or auth code.
SMTP_HOST=""
SMTP_PORT=465
SMTP_USERNAME=""
SMTP_PASSWORD=""
SMTP_FROM_EMAIL=""
SMTP_USE_SSL=true
SMTP_USE_STARTTLS=false
